[*.cs]
# STS001: Missing Localization Keys
dotnet_diagnostic.STS001.severity = warning

# STS002: No Localization JSON found
dotnet_diagnostic.STS002.severity = warning

# STS003: Custom Model usage
dotnet_diagnostic.STS003.severity = warning


charset = utf-8
indent_style = space
indent_size = 4
end_of_line = crlf
insert_final_newline = false
max_line_length = 120
tab_width = 4
trim_trailing_whitespace = false